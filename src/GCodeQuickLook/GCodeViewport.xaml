<UserControl x:Class="GCodeQuickLook.GCodeViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.Wpf.SharpDX">
    <Grid>
        <hx:Viewport3DX x:Name="Viewport"
                        ShowCoordinateSystem="True"
                        ShowViewCube="True"
                        ZoomExtentsWhenLoaded="True">
            <hx:DirectionalLight3D Color="White" Direction="-1,-1,-2" />
            <hx:AmbientLight3D Color="#404040" />
        </hx:Viewport3DX>
    </Grid>
</UserControl>
